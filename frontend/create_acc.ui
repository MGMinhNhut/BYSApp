  <property name="styleSheet">
   <string notr="true">
    /* Đồng bộ màu nền xanh xám nhạt */
    QDialog { 
        background-color: #F0F4F8; 
    }
    
    /* Đồng bộ ô nhập liệu: viền mảnh, bo góc 10px, màu chữ #333333 */
    QLineEdit {
        border: 1px solid #CFD8DC;
        border-radius: 10px;
        padding: 12px;
        background-color: #FFFFFF;
        font-size: 18pt;
        color: #333333;
    }
    
    /* Viền xanh đậm khi focus */
    QLineEdit:focus { 
        border: 2px solid #0078D4; 
    }
    
    /* Nút SIGN UP: Xanh doanh nghiệp, bo góc 10px, font 16pt */
    QPushButton#SignUp_button {
        background-color: #0078D4;
        color: white;
        font-size: 19pt;
        font-weight: bold;
        border-radius: 10px;
        min-height: 65px;
    }
    
    /* Hiệu ứng di chuột chuẩn Login */
    QPushButton#SignUp_button:hover {
        background-color: #005A9E;
    }
    
    /* Nút quay lại Login: Xanh đồng bộ, không gạch chân */
    QPushButton#Back_button {
        background-color: transparent;
        color: #0078D4;
        font-size: 11pt;
        font-weight: bold;
    }
   </string>
  </property>
  
