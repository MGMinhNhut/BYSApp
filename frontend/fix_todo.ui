  <property name="styleSheet">
   <string notr="true">
/* Đổi màu nền cho form */
QWidget#Form {
    background-color: #f4f9f9;
}

/* Style cho các dòng chữ giải thích */
QLabel {
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 15px;
    font-weight: bold;
    color: #34495e;
}

/* Style cho ô nhập liệu (bo góc, viền xám) */
QLineEdit {
    padding: 10px 12px;
    border: 1px solid #bdc3c7;
    border-radius: 6px;
    background-color: #ffffff;
    font-size: 16px;
    color: #2c3e50;
}

/* Hiệu ứng viền xanh khi nhấp chuột vào ô nhập liệu */
QLineEdit:focus {
    border: 2px solid #3498db;
}

/* Style cho nút bấm (màu xanh lá chuẩn, chữ in đậm) */
QPushButton {
    background-color: #2ecc71;
    color: white;
    border: none;
    border-radius: 6px;
    padding: 12px;
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 16px;
    font-weight: bold;
}

/* Hiệu ứng đậm màu hơn khi di chuột qua nút */
QPushButton:hover {
    background-color: #27ae60;
}

/* Hiệu ứng lún xuống khi nhấn nút */
QPushButton:pressed {
    background-color: #1e8449;
}
