<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>750</width>
    <height>550</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Ứng dụng Dự báo Thời tiết</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background-color: #F0F4F8;
    }
    
    QLineEdit#cityInput {
        background-color: #ffffff;
        border: 2px solid #2b2b2b;
        border-radius: 12px;
        padding: 10px 15px;
        font-size: 13pt;
        color: #333333;
    }
    QLineEdit#cityInput:focus {
        border: 2px solid #00aaff;
    }
    
    QPushButton#searchBtn {
        background-color: #0078D4;
        color: white;
        border: none;
        border-radius: 12px;
        padding: 10px 20px;
        font-size: 13pt;
        font-weight: bold;
    }
    QPushButton#searchBtn:hover { background-color: #33bbff; }
    QPushButton#searchBtn:pressed { background-color: #33bbff; }

    /* Sửa bo góc cho ScrollArea và làm trong suốt nền để thấy ảnh background */
    QScrollArea#scrollArea {
        border: 2px solid #2b2b2b;
        border-radius: 12px;
        background-color: transparent;
    }

    QScrollArea#scrollArea > QWidget > QWidget {
        background: transparent;
        border: none;
    }

    #scrollAreaWidgetContents {
        background-color: transparent;
        border-radius: 10px; 
        border: none;
    }

    QScrollBar:vertical {
        border: none;
        background: #F0F4F8;
        width: 10px;
        margin: 2px;
        border-radius: 5px;
    }
    QScrollBar::handle:vertical {
        background: #00aaff;
        border-radius: 5px;
        min-height: 20px;
    }
    QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; }
   </string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QVBoxLayout" name="verticalLayout">
    <property name="leftMargin"><number>20</number></property>
    <property name="topMargin"><number>20</number></property>
    <property name="rightMargin"><number>20</number></property>
    <property name="bottomMargin"><number>20</number></property>
    <item>
     <layout class="QHBoxLayout" name="searchLayout">
      <property name="spacing"><number>15</number></property>
      <item>
       <widget class="QLineEdit" name="cityInput">
        <property name="placeholderText">
         <string>Nhập tên thành phố (VD: Hanoi, London, Tokyo)...</string>
        </property>
       </widget>
      </item>
      <item>
       <widget class="QPushButton" name="searchBtn">
        <property name="cursor">
         <cursorShape>PointingHandCursor</cursorShape>
        </property>
        <property name="text">
         <string>Tìm kiếm</string>
        </property>
       </widget>
      </item>
     </layout>
    </item>
    <item>
     <widget class="QScrollArea" name="scrollArea">
      <property name="widgetResizable"><bool>true</bool></property>
      <widget class="QWidget" name="scrollAreaWidgetContents">
       <layout class="QVBoxLayout" name="forecastContainer">
        <property name="spacing"><number>15</number></property>
       </layout>
      </widget>
     </widget>
    </item>
   </layout>
  </widget>
 </widget>
